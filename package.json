{
  "name": "coherence",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev:docs": "pnpm --filter @coherence/docs dev",
    "tokens:build": "pnpm --filter @coherence/tokens build",
    "build": "pnpm -r build",
    "lint": "eslint .",
    "typecheck:docs": "pnpm --filter @coherence/docs exec tsc --noEmit",
    "typecheck:primitives": "pnpm --filter @coherence/primitives exec tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}